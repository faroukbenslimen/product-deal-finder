# Copy this file to .env and fill in your values

# Required: Google Gemini API key
# Get your free API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Port for the Express backend server
# Default: 4000
PORT=4000

# Optional: OpenRouter API key for fallback provider
# If set, the app will automatically fall back to OpenRouter when Gemini is unavailable
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenRouter model selection
# Default: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional: Daily AI model call cap to manage costs
# Default: 120
DAILY_MODEL_CALL_CAP=120
